import time
import logging
from tools.market_data import MarketData
from neo_main import NeoSystem
from core.blackboard import NeoBlackboard
from agents.trinity_council import TrinityCouncil

# --- 設定 ---
CHECK_INTERVAL = 30
VOLATILITY_THRESHOLD = 2.0
ALPHA_THRESHOLD = 5.0
COUNCIL_COOLDOWN = 1800  # 🆕 1800秒（30分）の冷却期間。Moltbook保護のため。

logger = logging.getLogger("neo.trigger")

def start_hybrid_radar():
    print("===================================================")
    print(f" 📡 Neo Hybrid Radar: SOCIAL DEFENSE MODE ")
    print("===================================================")
    
    initial_data = MarketData.fetch_token_data("VIRTUAL")
    anchor_price = float(initial_data.get("priceUsd", 0.0)) if initial_data else 0.0
    processed_alphas = {} 
    last_council_time = 0  # 🆕 最後に評議会を開いた時刻
    neo = NeoSystem()

    try:
        while True:
            current_time = time.time()

            # 1. 【ボラティリティ監視】 VIRTUAL (急変は即時対応)
            current_data = MarketData.fetch_token_data("VIRTUAL")
            if current_data and current_data.get("status") == "success":
                current_price = float(current_data.get("priceUsd", 0.0))
                change_percent = abs((current_price - anchor_price) / anchor_price) * 100 if anchor_price > 0 else 0
                if change_percent >= VOLATILITY_THRESHOLD:
                    print(f"\n🚨 [VOLATILITY] VIRTUAL moved {change_percent:.2f}%!")
                    neo.autonomous_post_cycle(topic=f"VIRTUAL価格が{change_percent:.2f}%変動")
                    anchor_price = current_price

            # 2. 【アルファ監視】 冷却期間を確認してから選別
            time_since_last = current_time - last_council_time
            if time_since_last < COUNCIL_COOLDOWN:
                wait_min = int((COUNCIL_COOLDOWN - time_since_last) / 60)
                alpha_status = f"Cooling Down ({wait_min}m left)"
            else:
                alpha_status = "Ready"

                board = NeoBlackboard.load()
                strat = board.get("strategic_intel", {})
                opps = strat.get("active_opportunities", {})

                eligible = []
                for s, d in opps.items():
                    if d.get("sharpe", 0.0) >= ALPHA_THRESHOLD and processed_alphas.get(s) != d.get("last_detected"):
                        eligible.append((s, d))

                if eligible:
                    eligible.sort(key=lambda x: x[1].get("sharpe", 0.0), reverse=True)
                    symbol, data = eligible[0]
                    
                    print(f"\n🔥 [TOP ALPHA] {symbol} (Sharpe: {data['sharpe']}) 採択")
                    try:
                        council = TrinityCouncil()
                        council.run(sentiment_score=1.0, context=f"Alpha Scan Hit: {data['sharpe']}", target_symbol=symbol)
                        processed_alphas[symbol] = data.get("last_detected")
                        last_council_time = time.time() # 🆕 時刻を更新
                        print(f"✅ Council Decision finalized. Entering {COUNCIL_COOLDOWN/60}m cooldown...")
                    except Exception as e:
                        print(f"⚠️ Council Error: {e}")
                        processed_alphas[symbol] = data.get("last_detected")

            print(f"[Radar] Watch: VIRTUAL ${anchor_price:.4f} | Alpha: {alpha_status}", end="\r")
            time.sleep(CHECK_INTERVAL)

    except KeyboardInterrupt:
        print("\n[Radar] Terminated by Commander.")

if __name__ == "__main__":
    start_hybrid_radar()
